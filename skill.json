{
  "name": "whatsapp",
  "version": "2.0.0",
  "description": "WhatsApp channel via lharries/whatsapp-mcp",
  "mcp": {
    "command": "uv",
    "args": ["--directory", "./whatsapp-mcp/whatsapp-mcp-server", "run", "main.py"],
    "pollTool": "list_messages",
    "pollIntervalMs": 3000,
    "pollTimestampArg": "after"
  },
  "scopeTemplate": {
    "send_message": { "allow": true, "scopedParams": ["recipient"] },
    "list_messages": { "allow": true, "scopedParams": ["chat_jid"] },
    "search_contacts": { "allow": true },
    "get_chat": { "allow": true, "scopedParams": ["chat_jid"] },
    "get_direct_chat_by_contact": { "allow": true },
    "get_contact_chats": { "allow": true, "scopedParams": ["jid"] },
    "get_last_interaction": { "allow": true, "scopedParams": ["jid"] },
    "get_message_context": { "allow": true },
    "send_file": { "allow": true, "scopedParams": ["recipient"] },
    "send_audio_message": { "allow": true, "scopedParams": ["recipient"] },
    "download_media": { "allow": true },
    "list_chats": { "allow": false }
  }
}
